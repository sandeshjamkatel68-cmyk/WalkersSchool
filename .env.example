# Local development - uses local video file
# For production on Vercel, set VITE_VIDEO_URL to your CDN URL

# Example CDN URLs (choose one):
# Using Vercel Blob Storage (recommended):
# VITE_VIDEO_URL=https://blob.vercel-storage.com/your-video-id

# Using Cloudinary:
# VITE_VIDEO_URL=https://res.cloudinary.com/your-cloud/video/upload/your-video.mp4

# Using any other CDN or hosting service:
# VITE_VIDEO_URL=https://your-cdn.com/hero.mp4
